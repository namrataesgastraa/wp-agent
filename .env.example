# ── Supabase ────────────────────────────────────────────────
# Found in Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-only, NEVER expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Meta WhatsApp Business API ──────────────────────────────
# Meta App Dashboard > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# Permanent token from a Meta System User (never expires)
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
# Any random string — you set the same value in Meta's webhook config
WHATSAPP_VERIFY_TOKEN=your-chosen-verify-token

# ── OpenRouter (OpenAI-compatible) ──────────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key
# Any CHAT model slug from https://openrouter.ai/models (NOT a rerank/embedding model)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Optional: system prompt that defines the agent's persona
AI_SYSTEM_PROMPT=You are a helpful WhatsApp assistant. Keep replies concise and friendly.
